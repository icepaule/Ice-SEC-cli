# Ollama API endpoint (change to your Ollama server IP)
OLLAMA_API_URL=http://localhost:11434

# Model to use (run 'sec models' to see available)
OLLAMA_MODEL=qwen2.5:14b

# SearXNG search endpoint (local Docker instance)
SEARXNG_URL=http://localhost:8888

# Docker analysis image name
ANALYSIS_IMAGE=ollama-cli-analysis

# Maximum agent iterations per query (tool call loops)
MAX_AGENT_ITERATIONS=15

# Context window size
NUM_CTX=16384
